    "# 长时间运行测试 - 10秒倒计时\n",
    "import time\n",
    "print(\"开始长时间运行任务...\")\n",
    "for i in range(10, 0, -1):\n",
    "    print(f\"倒计时: {i} 秒\")\n",
    "    time.sleep(1)\n",
    "print(\"任务完成！\")"
   ]
  }
